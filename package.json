{
  "name": "@pauldvlp/vp-templates",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo of pauldvlp's Vite+ templates and generators, indexed by @pauldvlp/create.",
  "author": "Paul Barahona <johanpaulbarahona@gmail.com> (https://github.com/pauldvlp/vp-templates)",
  "license": "MIT",
  "homepage": "https://github.com/pauldvlp/vp-templates",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauldvlp/vp-templates.git"
  },
  "bugs": "https://github.com/pauldvlp/vp-templates/issues",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test:watch": "vitest",
    "smoke:install": "node scripts/smoke-install.mjs",
    "registry": "verdaccio --config verdaccio.yaml --listen 4873",
    "publish:local": "pnpm -r run build && pnpm -r publish --registry http://localhost:4873 --no-git-checks",
    "relocal": "node scripts/relocal.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "verdaccio": "^6.7.4",
    "vitest": "^4"
  },
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.18.0"
  }
}
