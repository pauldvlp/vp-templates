{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "types": ["node", "vite/client"],

    /* Hono is plain TypeScript — no decorators, no metadata. Keep the module syntax strict so the
       Oxc transform can erase types without guessing; type-only imports carry an explicit `type`. */
    "verbatimModuleSyntax": true,

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "vite.config.ts"]
}
