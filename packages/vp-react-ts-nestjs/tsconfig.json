{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    // Resolve the internal shared kit to its source so esbuild inlines it into dist (tsconfig `paths`
    // matches are exempt from `--packages=external`), keeping the bundle self-contained — the kit is
    // private and never published.
    "baseUrl": ".",
    "paths": {
      "@pauldvlp/template-kit": ["../template-kit/src/index.ts"]
    }
  },
  "include": ["src", "bin", "__tests__"]
}
